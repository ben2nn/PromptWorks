# API 基础 URL - 开发环境
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# 生产环境示例
# NEXT_PUBLIC_API_BASE_URL=https://api.yourdomain.com/api/v1

# S3 / MinIO 存储配置（可选）
# 当后端使用 S3/MinIO 存储时，图片 URL 为 presigned URL，前端只需配置域名白名单
# MinIO 示例: minio.yourdomain.com:9000 或 minio.yourdomain.com
# AWS S3 示例: my-bucket.s3.us-east-1.amazonaws.com
NEXT_PUBLIC_S3_BUCKET_DOMAIN=

# 仅 AWS S3 需要，MinIO 不需要配置
NEXT_PUBLIC_S3_BUCKET_REGION=
